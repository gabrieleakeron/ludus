# Copy to .env and adjust as needed. Consumed by docker-compose.yml.

# Host ports (container ports are fixed: backend 8000, mcp 8765, frontend 80).
BACKEND_PORT=8000
MCP_PORT=8765
FRONTEND_PORT=8080

# Optional: enable live (non-mock) adapters that call the Anthropic API.
# Leave empty to run only the keyless mock.architect target.
ANTHROPIC_API_KEY=

# --- Local (non-Docker) development defaults, for reference ---
# LUDUS_DATABASE_URL=sqlite:///./data/ludus.db
# LUDUS_API_URL=http://localhost:8000      # used by the MCP server
# VITE_API_PROXY=http://localhost:8000     # used by the Vite dev proxy
