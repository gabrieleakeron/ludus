# Dev: leave VITE_API_URL unset to use the Vite proxy ("/api" -> localhost:8000).
# Override the proxy target if the backend runs elsewhere:
# VITE_API_PROXY=http://localhost:8000

# Production build (served by nginx): "/api" is proxied to the backend by nginx,
# so VITE_API_URL is normally left unset. Set it only for a cross-origin backend.
# VITE_API_URL=http://localhost:8000
